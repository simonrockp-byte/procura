# ─── Application ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_NAME=Procura

# ─── PostgreSQL ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://procura_user:password@localhost:5432/procura
# OR individual fields:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=procura
DB_USER=procura_user
DB_PASSWORD=changeme
DB_POOL_MAX=20

# ─── Redis ───────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-minimum-64-chars
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# ─── S3-Compatible Storage (delivery photos) ─────────────────────────────────────
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=af-south-1
S3_BUCKET=procura-deliveries
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key

# ─── WhatsApp (Meta Cloud API) ───────────────────────────────────────────────────
# Obtained from Meta Developer Console → WhatsApp → API Setup
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_APP_SECRET=your-meta-app-secret
# Per-organisation tokens are stored encrypted in the DB.
# The following is the default / fallback for single-tenant setups:
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# ─── Escalation Engine ───────────────────────────────────────────────────────────
DEFAULT_SLA_HOURS=72
ESCALATION_AUTO_ESCALATE_HOURS=2

# ─── Encryption (for storing WhatsApp tokens in DB) ──────────────────────────────
ENCRYPTION_KEY=32-byte-hex-key-change-in-production
